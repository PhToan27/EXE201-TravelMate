{
  "expo": {
    "owner": "toanpromax123",
    "name": "TravelMate",
    "slug": "travelmate",
    "scheme": "travelmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.travelmate.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F97316"
      },
      "package": "com.travelmate.app"
    },
    "web": {},
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "c7f61af0-7d40-43bb-8a40-79fbf0c693b0"
      }
    }
  }
}
