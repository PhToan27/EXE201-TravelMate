{
  "expo": {
    "owner": "toanpromax123",
    "name": "TravelMate",
    "slug": "travelmate",
    "scheme": "travelmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.travelmate.app",
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F97316"
      },
      "package": "com.travelmate.app"
    },
    "web": {},
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TravelMate can use your location to show directions to itinerary places."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c7f61af0-7d40-43bb-8a40-79fbf0c693b0"
      }
    }
  }
}
